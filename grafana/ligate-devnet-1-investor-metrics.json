    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "description": "Average wall-clock seconds per block over the last 5 minutes. Steady-state should match the DA layer's block time (Mocha: ~12s).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 26 },
      "id": 401,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "1 / rate(ligate_block_height[5m])",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Mean block time (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "description": "Fraction of the last 24 hours the ligate-node Prometheus target was reachable.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 26 },
      "id": 402,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "avg_over_time(up{job=~\".*ligate.*\"}[24h])",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Sequencer uptime (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "description": "p50, p95, p99 of REST request handling latency by route. The headline 'API responsiveness' metric.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 26 },
      "id": 403,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.50, sum(rate(ligate_rpc_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.95, sum(rate(ligate_rpc_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.99, sum(rate(ligate_rpc_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "RPC request latency",
      "type": "timeseries"
    }
